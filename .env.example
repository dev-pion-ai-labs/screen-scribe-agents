# Required — fill in before running locally or deploying.

# Gemini: default LLM provider. Free tier covers dev; paid tier is cheap.
# Get one: https://aistudio.google.com/apikey
GEMINI_API_KEY=
 
# OpenAI: only needed if you switch LLM_MODEL back to a gpt-* model.
# Get one: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Tavily: web search tool for the notes crew.
# Get one: https://app.tavily.com (free tier is fine)
TAVILY_API_KEY=

# Supabase. URL is public (same as the frontend's hardcoded value); the other
# two are dashboard secrets and must NOT be committed.
# Dashboard -> Project Settings -> API
#   - service_role  (a long JWT) -> SUPABASE_SERVICE_KEY
#   - JWT Settings -> JWT Secret -> SUPABASE_JWT_SECRET
SUPABASE_URL=https://vnyoexxeqdjpzekjteft.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# CORS — Vite dev port + any Vercel preview/prod domains.
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,https://screen-scribe-pilot.vercel.app,https://screen-pilot.up.railway.app

# Tunables.
# LLM_MODEL is passed straight to LiteLLM; the prefix picks the provider.
#   gemini/gemini-2.5-flash  -> default — newest flash, cheap & strong
#   gemini/gemini-2.0-flash  -> previous gen, slightly cheaper
#   gemini/gemini-2.5-pro    -> stronger but ~10x cost
#   gpt-4o                   -> OpenAI swap-back
LLM_MODEL=gemini/gemini-3.1-flash-lite-preview
LOG_LEVEL=info
